# =============================================================================
# Gridwolf Air-Gap Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# The load-and-run.sh script will generate secure defaults automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# Network Binding
# -----------------------------------------------------------------------------
# Address to bind exposed ports to. Default is 127.0.0.1 (localhost only).
# Set to 0.0.0.0 to allow access from other hosts on the network.
# WARNING: Only change this if you have proper firewall rules in place.
BIND_ADDRESS=127.0.0.1

# Port for the web UI (frontend)
FRONTEND_PORT=3000

# Port for the API server (backend)
BACKEND_PORT=8000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=gridwolf
POSTGRES_PASSWORD=GENERATE_ME
POSTGRES_DB=gridwolf
POSTGRES_PORT=5432

# Full connection string (constructed from above values at runtime)
GRIDWOLF_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379
GRIDWOLF_REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# JWT secret key for authentication tokens. Must be a long random string.
GRIDWOLF_SECRET_KEY=GENERATE_ME

# JWT token expiration in minutes (default: 480 = 8 hours)
GRIDWOLF_JWT_EXPIRY_MINUTES=480

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Allowed origins for CORS. In air-gapped mode this should only include
# the host where the UI is served from.
GRIDWOLF_CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
GRIDWOLF_LOG_LEVEL=INFO

# Log format: json or text
GRIDWOLF_LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Scan Storage
# -----------------------------------------------------------------------------
# Directory inside the container where scan result files are stored.
# This is mapped to a host volume in docker-compose.airgap.yml.
GRIDWOLF_SCAN_STORAGE_PATH=/app/data/scans

# Maximum scan file size in MB
GRIDWOLF_MAX_SCAN_FILE_SIZE_MB=100

# -----------------------------------------------------------------------------
# Celery Worker
# -----------------------------------------------------------------------------
# Concurrency level for the background worker (number of parallel tasks)
CELERY_WORKER_CONCURRENCY=2

# Task time limit in seconds (kill task if it exceeds this)
CELERY_TASK_TIME_LIMIT=3600
